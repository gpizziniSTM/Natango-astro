---
import { getCollection } from 'astro:content';
import scheduleData from '../content/schedule/table.json';

const courses = await getCollection('courses');
const lessons = scheduleData.lessons || [];

// Raggruppa le lezioni per giorno per facilitare la visualizzazione
const daysOfWeek = ['Lunedì', 'Martedì', 'Mercoledì', 'Giovedì', 'Venerdì', 'Sabato', 'Domenica'];
const sortedLessons = [...lessons].sort((a, b) => {
  return daysOfWeek.indexOf(a.day) - daysOfWeek.indexOf(b.day);
});
---

<section id="corsi-sez" class="section-padding courses-section">
  <div class="container">
    <div class="section-header animate-on-scroll radial-scale">
      <span class="subtitle">La nostra didattica</span>
      <h2>Corsi dell'Accademia</h2>
      <p class="section-desc">
        Un percorso formativo studiato nei minimi dettagli per tutti i livelli, dai primi passi all'avanzato.
      </p>
      <h3 class="courses-main-title">TANGO ARGENTINO</h3>
    </div>

    <!-- Corsi Cards Grid -->
    <div class="courses-grid animate-on-scroll radial-scale delay-1">
      {courses.map((course) => (
        <div class="course-card">
          <h3>{course.data.title}</h3>
          <p>{course.data.summary}</p>
        </div>
      ))}
    </div>

    <!-- Schedule Table -->
    <div class="schedule-container animate-on-scroll radial-scale delay-2">
      <div class="schedule-header">
        <span class="subtitle">Pianifica le tue lezioni</span>
        <h2>Orari dei Corsi</h2>
      </div>

      <!-- Desktop Table -->
      <div class="table-wrapper">
        <table class="schedule-table">
          <thead>
            <tr>
              <th>Giorno</th>
              <th>Orario</th>
              <th>Corso / Livello</th>
              <th>Maestro</th>
              <th>Sede</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            {sortedLessons.map((lesson) => (
              <tr>
                <td class="day-cell">{lesson.day}</td>
                <td class="time-cell"><i class="far fa-clock"></i> {lesson.time}</td>
                <td class="course-cell">{lesson.courseName}</td>
                <td class="teacher-cell">{lesson.teacher}</td>
                <td class="location-cell">
                  <span class={`badge-location ${lesson.location.toLowerCase().replace(/\s+/g, '-')}`}>
                    {lesson.location}
                  </span>
                </td>
                <td class="info-cell">{lesson.info || '-'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile List Layout -->
      <div class="mobile-schedule-list">
        {sortedLessons.map((lesson) => (
          <div class="mobile-lesson-card">
            <div class="lesson-header">
              <span class="lesson-day">{lesson.day}</span>
              <span class="lesson-time"><i class="far fa-clock"></i> {lesson.time}</span>
            </div>
            <h4 class="lesson-name">{lesson.courseName}</h4>
            <div class="lesson-details">
              <p><i class="fas fa-user-friends"></i> <strong>Maestro:</strong> {lesson.teacher}</p>
              <p>
                <i class="fas fa-map-marker-alt"></i> 
                <strong>Sede:</strong> 
                <span class={`badge-location ${lesson.location.toLowerCase().replace(/\s+/g, '-')}`}>{lesson.location}</span>
              </p>
              {lesson.info && <p class="lesson-note"><i class="fas fa-info-circle"></i> {lesson.info}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .courses-section {
    background-color: var(--bg-dark);
    position: relative;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem;
  }

  .subtitle {
    display: block;
    color: var(--accent-gold);
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 0.8rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .courses-main-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent-gold); /* Lilla */
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 1.5rem;
    text-align: center;
    font-family: var(--font-sans);
  }

  /* Cards Grid */
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 6rem;
  }

  .course-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: 2.5rem;
    border-radius: 8px;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
  }

  .course-card:hover {
    transform: translateY(-5px);
    border-color: rgba(197, 168, 128, 0.3);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .course-badge {
    align-self: flex-start;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--accent-gold);
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .course-card h3 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
  }

  .course-card p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .course-footer {
    border-top: 1px solid var(--border-color);
    padding-top: 1.2rem;
  }

  .course-more {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .course-card:hover .course-more {
    color: var(--accent-gold);
  }

  .course-more i {
    font-size: 0.8rem;
    transition: var(--transition);
  }

  .course-card:hover .course-more i {
    transform: translateX(4px);
  }

  /* Schedule Table */
  .schedule-container {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 3rem 1.5rem;
  }

  .schedule-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .schedule-header h2 {
    font-size: 2.2rem;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .schedule-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.95rem;
  }

  .schedule-table th {
    font-family: var(--font-sans);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--accent-gold);
    padding: 1.2rem 1rem;
    border-bottom: 2px solid var(--border-color);
  }

  .schedule-table td {
    padding: 1.2rem 1rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-secondary);
  }

  .schedule-table tr:last-child td {
    border-bottom: none;
  }

  .schedule-table tr:hover td {
    background-color: rgba(255, 255, 255, 0.01);
    color: var(--text-primary);
  }

  .day-cell {
    font-weight: 700;
    color: var(--text-primary) !important;
    white-space: nowrap;
  }

  .time-cell {
    white-space: nowrap;
  }

  .time-cell i {
    color: var(--accent-gold);
    margin-right: 0.4rem;
  }

  .course-cell {
    font-weight: 600;
    color: var(--text-primary) !important;
  }

  .badge-location {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    white-space: nowrap;
    display: inline-block;
  }

  .badge-location.tango-loft {
    background-color: rgba(155, 81, 224, 0.1);
    color: var(--accent-gold);
    border: 1px solid rgba(155, 81, 224, 0.2);
  }

  .badge-location.gotan-club {
    background-color: rgba(6, 147, 227, 0.1);
    color: var(--accent-red);
    border: 1px solid rgba(6, 147, 227, 0.2);
  }

  .badge-location.entrambe {
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Mobile layout list */
  .mobile-schedule-list {
    display: none;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 992px) {
    .schedule-container {
      padding: 2rem;
    }
  }

  @media (max-width: 768px) {
    .table-wrapper {
      display: none;
    }

    .mobile-schedule-list {
      display: flex;
    }

    .mobile-lesson-card {
      background-color: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 1.5rem;
    }

    .lesson-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.8rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.6rem;
    }

    .lesson-day {
      font-weight: 700;
      color: var(--accent-gold);
      text-transform: uppercase;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
    }

    .lesson-time {
      font-size: 0.85rem;
      color: var(--text-secondary);
    }

    .lesson-time i {
      color: var(--accent-gold);
      margin-right: 0.3rem;
    }

    .lesson-name {
      font-size: 1.15rem;
      font-weight: 600;
      margin-bottom: 0.8rem;
    }

    .lesson-details p {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-bottom: 0.4rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .lesson-details i {
      color: var(--accent-gold);
      width: 16px;
    }

    .lesson-note {
      margin-top: 0.6rem;
      font-style: italic;
      color: var(--text-secondary);
    }
  }
</style>
