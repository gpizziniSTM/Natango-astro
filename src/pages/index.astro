---
import Layout from '../layouts/Layout.astro';
import CoursesSection from '../components/CoursesSection.astro';
import Accordion from '../components/Accordion.astro';
import generalSettings from '../content/settings/general.json';
import { getCollection } from 'astro:content';

const locations = await getCollection('locations');
---

<Layout title="Accademia Natango | Scuola di Tango Argentino a Roma">
  
  <!-- Hero Section -->
  <section id="hero" class="hero-section">
    <div class="hero-slideshow">
      <div class="slide" style="background-image: url('/wp-content/uploads/2025/11/DSC01833-scaled.jpg');"></div>
      <div class="slide" style="background-image: url('/wp-content/uploads/2025/11/HIHW6679.jpg');"></div>
      <div class="slide" style="background-image: url('/wp-content/uploads/2025/11/francysantisito-e1764334249594.webp');"></div>
    </div>
    <div class="hero-bg-overlay"></div>
    <div class="container hero-container">
      <div class="hero-content">
        <span class="hero-badge animate-on-scroll fade-in-left"><i class="fas fa-music"></i> Accademia Natango</span>
        <h1 class="animate-on-scroll fade-in-left delay-1">{generalSettings.heroTitle}</h1>
        <p class="animate-on-scroll fade-in-left delay-2">{generalSettings.heroSubtitle}</p>
        <div class="hero-actions animate-on-scroll fade-in-left delay-3">
          <a href="#lezione-gratuita-sez" class="btn btn-red">Richiedi Lezione Gratuita</a>
          <a href="#corsi-sez" class="btn btn-outline">Vedi i Corsi</a>
        </div>
      </div>
    </div>
  </section>

  <!-- About / Maestro Section (Cosa ci rende diversi) -->
  <section id="fdb-sez" class="section-padding about-section">
    <div class="container about-grid">
      <div class="about-left">
        <span class="subtitle animate-on-scroll fade-in-left">Cosa ci rende diversi</span>
        <h2 class="animate-on-scroll fade-in-left delay-1">Francesca Del Buono</h2>
        <h3 class="animate-on-scroll fade-in-left delay-2">25 Anni di Esperienza tra Italia, Europa ed Argentina</h3>
        <p class="about-text animate-on-scroll fade-in-left delay-3">
          Francesca Del Buono porta in Accademia una visione unica del tango argentino, maturata in decenni di carriera internazionale. La sua didattica unisce rigore tecnico, espressione artistica ed eleganza, guidando gli allievi a scoprire l'essenza dell'abbraccio e del movimento autentico.
        </p>
        
        <!-- Video Promo Card -->
        <div class="video-promo-card animate-on-scroll fade-in-left delay-3">
          <div class="video-thumbnail">
            <div class="video-overlay">
              <button class="play-btn" id="openVideoBtn" aria-label="Riproduci video di presentazione">
                <i class="fas fa-play"></i>
              </button>
              <span>Guarda il video di presentazione</span>
            </div>
          </div>
        </div>
      </div>

      <div class="about-right">
        <div class="maestra-img-wrapper animate-on-scroll fade-in-left">
          <img src="/wp-content/uploads/2025/11/IMG_20250913_163518_949.webp" alt="Francesca Del Buono" class="maestra-img" />
        </div>
        <!-- Accordion dei Corsi -->
        <div class="animate-on-scroll fade-in-left delay-1">
          <Accordion />
        </div>
      </div>
    </div>
  </section>

  <!-- Courses and Schedule Section -->
  <CoursesSection />

  <!-- Sedi Section -->
  <section id="sedi-sez" class="section-padding sedi-section">
    <div class="container">
      <div class="section-header text-center animate-on-scroll fade-in-up">
        <span class="subtitle">DOVE TROVARCI</span>
        <h2>Le Nostre Sedi</h2>
        <p class="section-desc">Sale ampie e specchiate, perfette per l'insegnamento del tango argentino.</p>
      </div>

      <div class="sedi-grid animate-on-scroll fade-in-up delay-1">
        {locations.map((loc) => (
          <div class="sede-card">
            <div class="sede-icon">
              <i class="fas fa-map-marked-alt"></i>
            </div>
            <h3>{loc.data.name}</h3>
            <p class="sede-address"><i class="fas fa-map-pin"></i> {loc.data.address}</p>
            <div class="sede-description">
              {loc.body}
            </div>
            {loc.data.mapsLink && (
              <a href={loc.data.mapsLink} target="_blank" class="btn btn-outline btn-sm">
                Apri su Google Maps <i class="fas fa-external-link-alt"></i>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lezione Gratuita / Contatti Section -->
  <section id="lezione-gratuita-sez" class="section-padding contacts-section">
    <div class="container contact-grid">
      <div class="contact-info-col animate-on-scroll fade-in-up">
        <span class="subtitle">Contattaci</span>
        <h2>Prenota la tua Lezione di Prova Gratuita</h2>
        <p class="contact-desc">
          Compila il modulo per prenotare la tua lezione di prova. Ti ricontatteremo al più presto per confermare la data e l'orario. Non serve essere in coppia!
        </p>
        <div class="contact-methods">
          <div class="method-item">
            <div class="icon-box"><i class="fas fa-phone-alt"></i></div>
            <div>
              <h4>Telefono</h4>
              <p><a href={`tel:${generalSettings.phone.replace(/\s+/g, '')}`}>{generalSettings.phone}</a></p>
            </div>
          </div>
          <div class="method-item">
            <div class="icon-box"><i class="fas fa-envelope"></i></div>
            <div>
              <h4>Email</h4>
              <p><a href={`mailto:${generalSettings.email}`}>{generalSettings.email}</a></p>
            </div>
          </div>
          <div class="method-item">
            <div class="icon-box"><i class="fab fa-whatsapp"></i></div>
            <div>
              <h4>WhatsApp</h4>
              <p><a href={`https://wa.me/393392737619?text=${encodeURIComponent(generalSettings.whatsappText)}`} target="_blank">Scrivici direttamente</a></p>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form-col animate-on-scroll fade-in-up delay-1">
        <!-- Form collegato a Web3Forms (servizio gratuito e serverless) -->
        <!-- Per attivarlo in produzione basta inserire la propria email o chiave API -->
        <form action="https://api.web3forms.com/submit" method="POST" class="contact-form">
          <input type="hidden" name="access_key" value="04d77041-e95f-46b6-8bef-4a19fd658b46" />
          <input type="hidden" name="subject" value="Nuova richiesta lezione di prova - Natango" />
          <input type="checkbox" name="botcheck" id="" style="display: none;" />

          <div class="form-row">
            <div class="form-group">
              <label for="name">Nome *</label>
              <input type="text" id="name" name="name" required placeholder="Inserisci il tuo nome" />
            </div>
            <div class="form-group">
              <label for="surname">Cognome *</label>
              <input type="text" id="surname" name="surname" required placeholder="Inserisci il tuo cognome" />
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required placeholder="Inserisci la tua email" />
          </div>

          <div class="form-group">
            <label for="phone">Telefono *</label>
            <input type="tel" id="phone" name="phone" required placeholder="Inserisci il tuo numero di telefono" />
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="location-select">Sede di preferenza</label>
              <select id="location-select" name="sede">
                <option value="Non specificato">Seleziona una sede...</option>
                <option value="Tango Loft">Tango Loft</option>
                <option value="Gotan Club">Gotan Club</option>
              </select>
            </div>
            <div class="form-group">
              <label for="level-select">Livello</label>
              <select id="level-select" name="livello">
                <option value="Principiante">Principiante Assoluto</option>
                <option value="Intermedio">Intermedio</option>
                <option value="Avanzato">Avanzato</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="message">Messaggio / Note</label>
            <textarea id="message" name="message" rows="4" placeholder="Eventuali domande o dettagli aggiuntivi..."></textarea>
          </div>

          <button type="submit" class="btn btn-red btn-block">Invia Richiesta</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Video Dialog Modale (Nativo HTML5 Dialog) -->
  <dialog id="videoDialog" class="video-modal">
    <div class="modal-content">
      <button class="close-modal-btn" id="closeVideoBtn" aria-label="Chiudi video">&times;</button>
      <div class="iframe-container">
        <iframe 
          id="promoVideoIframe"
          src="" 
          title="YouTube video player" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen>
        </iframe>
      </div>
    </div>
  </dialog>

</Layout>

<script>
  const openVideoBtn = document.getElementById('openVideoBtn');
  const closeVideoBtn = document.getElementById('closeVideoBtn');
  const videoDialog = document.getElementById('videoDialog') as HTMLDialogElement | null;
  const promoVideoIframe = document.getElementById('promoVideoIframe') as HTMLIFrameElement | null;
  const videoId = '1Ltt80bq-8Y';

  // Apri Modale Video
  openVideoBtn?.addEventListener('click', () => {
    if (videoDialog && promoVideoIframe) {
      promoVideoIframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
      videoDialog.showModal();
      document.body.classList.add('no-scroll');
    }
  });

  // Chiudi Modale Video
  const closeVideo = () => {
    if (videoDialog && promoVideoIframe) {
      promoVideoIframe.src = '';
      videoDialog.close();
      document.body.classList.remove('no-scroll');
    }
  };

  closeVideoBtn?.addEventListener('click', closeVideo);

  // Chiudi cliccando sullo sfondo
  videoDialog?.addEventListener('click', (e) => {
    if (e.target === videoDialog) {
      closeVideo();
    }
  });

  // Intersection Observer per animazioni a scorrimento
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  const animateElements = document.querySelectorAll('.animate-on-scroll');
  animateElements.forEach(el => observer.observe(el));
</script>

<style>
  .subtitle {
    display: block;
    color: var(--accent-gold);
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 0.8rem;
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-slideshow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transform: scale(1.08);
    animation: slideshowAnimation 15s infinite;
  }

  .slide:nth-child(1) {
    animation-delay: 0s;
  }
  .slide:nth-child(2) {
    animation-delay: 5s;
  }
  .slide:nth-child(3) {
    animation-delay: 10s;
  }

  @keyframes slideshowAnimation {
    0% {
      opacity: 0;
      transform: scale(1.08);
      animation-timing-function: ease-in;
    }
    8% {
      opacity: 1;
      transform: scale(1.03);
      animation-timing-function: ease-out;
    }
    33% {
      opacity: 1;
      transform: scale(1.03);
    }
    41% {
      opacity: 0;
      transform: scale(1.08);
    }
    100% {
      opacity: 0;
    }
  }

  .hero-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(10, 10, 10, 0.75) 0%, rgba(10, 10, 10, 0.35) 100%);
    z-index: 1;
  }

  .hero-container {
    position: relative;
    z-index: 2;
  }

  .hero-content {
    max-width: 800px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-gold);
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    margin-bottom: 2rem;
    background: rgba(255, 255, 255, 0.02);
  }

  .hero-content h1 {
    font-size: 2.8rem;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  .hero-content p {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    max-width: 600px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: 4px;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-align: center;
    border: 1px solid transparent;
  }

  .btn-red {
    background-color: var(--accent-red);
    color: var(--text-primary);
  }

  .btn-red:hover {
    background-color: var(--accent-red-hover);
    box-shadow: 0 5px 15px rgba(198, 40, 40, 0.3);
  }

  .btn-outline {
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-primary);
  }

  .btn-outline:hover {
    border-color: var(--text-primary);
    background-color: rgba(255, 255, 255, 0.05);
  }

  .btn-sm {
    padding: 0.6rem 1.2rem;
    font-size: 0.75rem;
  }

  .btn-block {
    display: block;
    width: 100%;
  }

  /* About Section */
  .about-section {
    background-color: var(--bg-card);
    border-bottom: 1px solid var(--border-color);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .about-left h2 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .about-left h3 {
    font-size: 1.4rem;
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--accent-gold);
    margin-bottom: 2rem;
  }

  .about-text {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  .video-promo-card {
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
  }

  .video-thumbnail {
    height: 180px;
    background-image: linear-gradient(135deg, #1f1f1f 0%, #0d0d0d 100%);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: var(--text-primary);
    font-size: 0.95rem;
  }

  .play-btn {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: var(--accent-red);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    box-shadow: 0 0 20px rgba(198, 40, 40, 0.4);
  }

  .play-btn:hover {
    background-color: var(--accent-gold);
    color: #000000;
    box-shadow: 0 0 20px rgba(197, 168, 128, 0.6);
    transform: scale(1.08);
  }

  .maestra-img-wrapper {
    width: 100%;
    max-height: 480px;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    margin-bottom: 2rem;
  }

  .maestra-img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    object-position: center 20%;
    transition: var(--transition);
  }

  .maestra-img-wrapper:hover .maestra-img {
    transform: scale(1.03);
  }

  /* Sedi Section */
  .sedi-section {
    border-bottom: 1px solid var(--border-color);
  }

  .section-header.text-center {
    text-align: center;
    margin-bottom: 4rem;
  }

  .sedi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .sede-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 3rem 2.5rem;
    text-align: center;
    transition: var(--transition);
  }

  .sede-card:hover {
    border-color: rgba(197, 168, 128, 0.3);
    transform: translateY(-5px);
  }

  .sede-icon {
    font-size: 2.2rem;
    color: var(--accent-gold);
    margin-bottom: 1.5rem;
  }

  .sede-card h3 {
    font-size: 1.8rem;
    margin-bottom: 0.8rem;
  }

  .sede-address {
    font-size: 0.95rem;
    color: var(--accent-gold);
    margin-bottom: 1.5rem;
  }

  .sede-address i {
    font-size: 0.85rem;
  }

  .sede-description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  /* Contacts Section */
  .contacts-section {
    background-color: var(--bg-card);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }

  .contact-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .method-item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .icon-box {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: rgba(197, 168, 128, 0.1);
    color: var(--accent-gold);
    border: 1px solid rgba(197, 168, 128, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
  }

  .method-item h4 {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    margin-bottom: 0.2rem;
  }

  .method-item p {
    font-size: 1.15rem;
    font-weight: 600;
  }

  .method-item a:hover {
    color: var(--accent-gold);
  }

  /* Contact Form */
  .contact-form {
    background: var(--bg-dark);
    border: 1px solid var(--border-color);
    padding: 3rem;
    border-radius: 8px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    margin-bottom: 0.6rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: var(--transition);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--accent-gold);
    background-color: rgba(255, 255, 255, 0.04);
    outline: none;
  }

  /* Video Modal */
  .video-modal {
    margin: auto;
    border: none;
    border-radius: 8px;
    background: transparent;
    padding: 0;
    max-width: 900px;
    width: 90%;
    box-shadow: 0 20px 50px rgba(0,0,0,0.8);
    overflow: visible;
  }

  .video-modal::backdrop {
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(5px);
  }

  .modal-content {
    position: relative;
    background-color: #000;
    border-radius: 8px;
    overflow: hidden;
  }

  .close-modal-btn {
    position: absolute;
    top: -45px;
    right: 0;
    background: transparent;
    border: none;
    color: #fff;
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    z-index: 1010;
  }

  .iframe-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
  }

  .iframe-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Responsive styling */
  @media (max-width: 992px) {
    .hero-content h1 {
      font-size: 2.2rem;
    }
    
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 1.8rem;
    }
    
    .hero-content p {
      font-size: 1.1rem;
    }

    .about-left h2 {
      font-size: 2.2rem;
    }

    .contact-form {
      padding: 2rem 1.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
    
    .maestra-img-wrapper {
      max-height: 380px;
    }
    
    .maestra-img {
      height: 380px;
    }
  }
</style>
